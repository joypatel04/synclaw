# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site
CONVEX_DEPLOYMENT=your-deployment-key

# Umami Analytics
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id

# Auth (Convex Auth - GitHub + Google OAuth)
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret
AUTH_GOOGLE_ID=789861589331-lcn3e2hiq6j9jfphd0cqkno675r7dids.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# OpenClaw Gateway
#
# OpenClaw connection settings are stored per-workspace in Convex and configured
# via Synclaw UI at `/settings/openclaw` (no NEXT_PUBLIC_OPENCLAW_* env vars).
#
# Convex env var required for encrypting tokens at rest (set via `bunx convex env set`):
# OPENCLAW_TOKEN_ENCRYPTION_KEY_HEX=<openssl rand -hex 32>
#
# Managed OpenClaw provisioning (Convex env vars, not NEXT_PUBLIC_*):
# HETZNER_API_TOKEN=...
# MANAGED_HETZNER_IMAGE=ubuntu-24.04
# MANAGED_DEFAULT_SERVER_PROFILE=starter
# Optional explicit type override (slug only, not numeric/deprecated IDs):
# MANAGED_HETZNER_SERVER_TYPE=cx22
# Optional fallback if primary type fails:
# MANAGED_HETZNER_FALLBACK_SERVER_TYPE=cx22
#
# Managed bootstrap/gateway integration:
# Canonical control-plane base (preferred; used for both bootstrap and routing):
# MANAGED_CONTROL_PLANE_BASE_URL=https://synclaw.in/control
# Backward-compatible overrides:
# MANAGED_BOOTSTRAP_API_BASE_URL=https://synclaw.in/control
# MANAGED_BOOTSTRAP_API_TOKEN=...
# MANAGED_BOOTSTRAP_USER=root
# MANAGED_BOOTSTRAP_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----..."
# MANAGED_BOOTSTRAP_TIMEOUT_MS=120000
# MANAGED_BOOTSTRAP_STRICT=false
# MANAGED_GATEWAY_API_BASE_URL=https://synclaw.in/control
# MANAGED_GATEWAY_API_TOKEN=...
# MANAGED_GATEWAY_STRICT=false
# MANAGED_PROVIDER_AUTOCONFIG_ENABLED=true
# MANAGED_HEALTHCHECK_TIMEOUT_MS=60000
# MANAGED_UPSTREAM_WS_PORT=18789
# MANAGED_OPENCLAW_WSS_TEMPLATE=wss://synclaw.in/ws/{workspaceId}

# App
SYNCLAW_EDITION=commercial
NEXT_PUBLIC_SYNCLAW_EDITION=commercial
# Managed/assisted launch exposure (recommended false in public OSS beta)
SYNCLAW_MANAGED_BETA_ENABLED=false
SYNCLAW_ASSISTED_LAUNCH_ENABLED=false
NEXT_PUBLIC_MANAGED_BETA_ENABLED=false
NEXT_PUBLIC_ASSISTED_LAUNCH_BETA_ENABLED=false
NEXT_PUBLIC_APP_NAME="Synclaw"
NEXT_PUBLIC_APP_URL=https://mission-control.yourdomain.com
# Optional runtime override (JSON string) for brand copy
# NEXT_PUBLIC_BRAND_CONFIG_JSON='{"product":{"name":"New Name"}}'
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_WEBHOOKS_ENABLED=true
NEXT_PUBLIC_OPENCLAW_FILES_ENABLED=false

# Razorpay Billing (Phase A India alternative)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
RAZORPAY_PLAN_STARTER_MONTHLY_INR=plan_...
RAZORPAY_PLAN_STARTER_YEARLY_INR=plan_...
RAZORPAY_PLAN_PRO_MONTHLY_INR=plan_...
RAZORPAY_PLAN_PRO_YEARLY_INR=plan_...
RAZORPAY_PLAN_STARTER_MONTHLY_USD=plan_...
RAZORPAY_PLAN_STARTER_YEARLY_USD=plan_...
RAZORPAY_PLAN_PRO_MONTHLY_USD=plan_...
RAZORPAY_PLAN_PRO_YEARLY_USD=plan_...

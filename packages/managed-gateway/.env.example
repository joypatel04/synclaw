# Managed Gateway runtime
PORT=8788
MANAGED_GATEWAY_API_TOKEN=d6b894a5566f8391230ca85706f4b05a87f8db61ba9c692a632b5489b3fd4515

# Route store
MANAGED_GATEWAY_DB_PATH=/data/routes.db

# Public route shape
WORKSPACE_WS_PATH_PREFIX=/ws

# Upstream workspace server settings
MANAGED_UPSTREAM_WS_SCHEME=ws
MANAGED_UPSTREAM_WS_PATH=/
MANAGED_UPSTREAM_WS_PORT=18789
# Origin header forwarded by WS proxy when upstream OpenClaw enforces allowedOrigins
MANAGED_UPSTREAM_WS_ORIGIN=https://synclaw.in

# Timeouts
MANAGED_BOOTSTRAP_TIMEOUT_MS=180000
MANAGED_HEALTHCHECK_TIMEOUT_MS=12000

# Real mode: require custom SSH bootstrap script that installs/runs OpenClaw.
MANAGED_REQUIRE_CUSTOM_BOOTSTRAP_SCRIPT=true

# Optional: custom SSH bootstrap script for real OpenClaw install.
# Supported placeholders:
# {{WORKSPACE_ID}} {{JOB_ID}} {{INSTANCE_ID}} {{HOST}} {{REGION}}
# {{UPSTREAM_PORT}} {{OPENCLAW_GATEWAY_TOKEN}} {{FILES_BRIDGE_TOKEN}}
# {{FILES_BRIDGE_PORT}} {{FILES_BRIDGE_ROOT_PATH}}
# MANAGED_BOOTSTRAP_SCRIPT=set -euo pipefail; ...
MANAGED_BOOTSTRAP_SCRIPT_FILE=/app/bootstrap/openclaw-bootstrap.sh

# Files bridge defaults for managed hosts
MANAGED_FILES_BRIDGE_PORT=8787
MANAGED_FILES_BRIDGE_ROOT_PATH=/root/.openclaw

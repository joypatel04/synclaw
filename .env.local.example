# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site
CONVEX_DEPLOYMENT=your-deployment-key

# Auth (Convex Auth - GitHub OAuth)
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# OpenClaw Gateway
#
# OpenClaw connection settings are stored per-workspace in Convex and configured
# via Sutraha HQ UI at `/settings/openclaw` (no NEXT_PUBLIC_OPENCLAW_* env vars).
#
# Convex env var required for encrypting tokens at rest (set via `bunx convex env set`):
# OPENCLAW_TOKEN_ENCRYPTION_KEY_HEX=<openssl rand -hex 32>

# App
NEXT_PUBLIC_APP_NAME="Sutraha HQ"
NEXT_PUBLIC_APP_URL=https://mission-control.yourdomain.com
# Optional runtime override (JSON string) for brand copy
# NEXT_PUBLIC_BRAND_CONFIG_JSON='{"product":{"name":"New Name"}}'
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_WEBHOOKS_ENABLED=true
NEXT_PUBLIC_AUTOPILOT_ENABLED=false
NEXT_PUBLIC_OPENCLAW_FILES_ENABLED=false
# Razorpay Billing (Phase A India alternative)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
RAZORPAY_PLAN_STARTER_MONTHLY_INR=plan_...
RAZORPAY_PLAN_STARTER_YEARLY_INR=plan_...
RAZORPAY_PLAN_PRO_MONTHLY_INR=plan_...
RAZORPAY_PLAN_PRO_YEARLY_INR=plan_...
RAZORPAY_PLAN_STARTER_MONTHLY_USD=plan_...
RAZORPAY_PLAN_STARTER_YEARLY_USD=plan_...
RAZORPAY_PLAN_PRO_MONTHLY_USD=plan_...
RAZORPAY_PLAN_PRO_YEARLY_USD=plan_...
